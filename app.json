{
  "expo": {
    "name": "Neuro Wake",
    "slug": "neuro-wake",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "neurowake",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logoAlarma.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F14"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.aarongpm.appalarma"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-audio",
      [
        "expo-notifications",
        {
          "defaultChannel": "alarms-default",
          "sounds": [
            "./assets/sounds/blendertimer_cyber_alarms_synthesized_116358.mp3",
            "./assets/sounds/dennish18_biohazard_alarm_143105.mp3",
            "./assets/sounds/freesound_community_056338_25_alien_alarms_87068.mp3",
            "./assets/sounds/freesound_community_alarm_26718.mp3",
            "./assets/sounds/freesound_community_alarm_no3_14864.mp3",
            "./assets/sounds/freesound_community_facility_siren_loopable_100687.mp3",
            "./assets/sounds/freesound_community_imminent2_80967.mp3",
            "./assets/sounds/freesound_community_meltdown_73617.mp3",
            "./assets/sounds/freesound_community_multiple_tornado_alarms_17375.mp3",
            "./assets/sounds/freesound_community_thunder_69076.mp3",
            "./assets/sounds/jeremayjimenez_greece_eas_alarm_451404.mp3",
            "./assets/sounds/jeremayjimenez_saudi_arabia_eas_alarm_1924_526917.mp3"
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0F14",
          "image": "./assets/logoAlarma.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "efd7c3e2-09ed-4110-a1db-2d88ca1af551"
      }
    }
  }
}
